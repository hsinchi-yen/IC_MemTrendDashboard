# 多階段建置：先編譯，再運行
# ============================================================================

# ============================================================================
# 階段 1: 編譯前端 (Build Stage)
# ============================================================================
FROM node:20-alpine AS builder

WORKDIR /app

# 複製依賴宣告
COPY package.json package-lock.json ./

# 安裝依賴
RUN npm ci

# 複製源碼
COPY . .

# 編譯為靜態檔案
RUN npm run build

# ============================================================================
# 階段 2: 運行前端 (Runtime Stage)
# ============================================================================
FROM node:20-alpine

WORKDIR /app

# 安裝生產用 http-server（輕量級靜態檔案伺服器）
RUN npm install -g http-server

# 從編譯階段複製編譯結果
COPY --from=builder /app/dist /app/dist

# 曝露埠口
EXPOSE 8510

# 啟動伺服器
CMD ["http-server", "dist", "-p", "8510", "--cors"]
