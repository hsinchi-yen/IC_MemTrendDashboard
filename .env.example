# 環境變數設定範例 — 複製此檔案為 .env 並填入實際值

# ============================================================
# 資料庫 (必填)
# ============================================================
DATABASE_URL=postgresql+asyncpg://memdash:changeme@localhost:5433/memdash
POSTGRES_DB=memdash
POSTGRES_USER=memdash
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5433
BACKEND_PORT=18000

# ============================================================
# 股票資料源
# ============================================================
# FinMind API (台股主要來源, 美股備援)
FINMIND_TOKEN=

# Alpha Vantage (美股備援)
ALPHA_VANTAGE_KEY=

# ============================================================
# 告警推播 (Phase 3)
# ============================================================
# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Line Notify
LINE_NOTIFY_TOKEN=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=

# ============================================================
# AI / LLM (Phase 5)
# ============================================================
LLM_API_KEY=
LLM_PROVIDER=gemini
